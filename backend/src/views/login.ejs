<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SoundStore - Login Admin</title>
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="login-container">
        <img src="/images/logo-soundstore.png" alt="SoundStore" class="login-logo">
        <h1>SoundStore</h1>
        <h2>Panel de Administrador</h2>

        <form action="/admin/login" method="POST" class="login-form">
            <% if (typeof error !== 'undefined') { %>
                <p class="error-msg"><%= error %></p>
            <% } %>

            <label for="email">Correo</label>
            <input type="email" id="email" name="user_email" required>

            <label for="password">Contraseña</label>
            <input type="password" id="password" name="user_password" required>

            <button type="submit" class="btn-primary">Ingresar</button>
            <button type="button" id="btnAccesoRapido" class="btn-secondary">Acceso rápido (testers)</button>
        </form>
    </div>

    <script>
        document.getElementById('btnAccesoRapido').addEventListener('click', () => {
            document.getElementById('email').value = 'admin@soundstore.com';
            document.getElementById('password').value = 'admin123';
        });
    </script>
</body>
</html>