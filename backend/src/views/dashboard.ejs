<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('header', { tituloPagina: 'Dashboard' }) %>
</head>
<body class="panel-admin">
    <%- include('navbar', { activo: 'dashboard' }) %>

    <div class="contenido-panel">

        <h1 class="titulo-seccion">Productos</h1>

        <% if (typeof errorCarga !== 'undefined') { %>
            <p class="error-msg"><%= errorCarga %></p>
        <% } %>

        <table class="tabla-admin">
            <thead>
                <tr>
                    <th>Imagen</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof productos !== 'undefined' && productos.length > 0) { %>
                    <% productos.forEach(function(producto) { %>
                        <tr>
                            <td>
                                <% if (producto.product_image) { %>
                                    <img src="<%= producto.product_image %>" alt="<%= producto.product_name %>" class="thumb-producto">
                                <% } else { %>
                                    <span class="sin-imagen">Sin imagen</span>
                                <% } %>
                            </td>
                            <td><%= producto.product_name %></td>
                            <td><%= producto.product_category %></td>
                            <td>$<%= producto.product_price %></td>
                            <td>
                                <span class="badge <%= producto.product_active ? 'badge-activo' : 'badge-inactivo' %>">
                                    <%= producto.product_active ? 'Activo' : 'Inactivo' %>
                                </span>
                            </td>
                            <td class="acciones-tabla">
                                <a href="/admin/productos/<%= producto.product_id %>/editar" class="btn-accion btn-editar">Editar</a>
                                <form action="/admin/productos/<%= producto.product_id %>/baja" method="POST" class="form-inline">
                                    <button type="submit" class="btn-accion btn-baja">
                                        <%= producto.product_active ? 'Desactivar' : 'Activar' %>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="celda-vacia">No hay productos cargados todavía.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <h1 class="titulo-seccion">Últimas ventas</h1>

        <table class="tabla-admin">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Fecha</th>
                    <th>Total</th>
                    <th>Productos</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof ventas !== 'undefined' && ventas.length > 0) { %>
                    <% ventas.forEach(function(venta) { %>
                        <tr>
                            <td><%= venta.sale_customer_name %></td>
                            <td><%= new Date(venta.sale_date).toLocaleDateString('es-AR') %></td>
                            <td>$<%= venta.sale_total %></td>
                            <td>
                                <% if (venta.Products && venta.Products.length > 0) { %>
                                    <%= venta.Products.map(function(p) { return p.product_name; }).join(', ') %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="celda-vacia">No hay ventas registradas todavía.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

    </div>
</body>
</html>
