<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('header', { tituloPagina: 'Dashboard' }) %>
</head>
<body class="panel-admin">
    <%- include('navbar', { activo: 'dashboard' }) %>

    <div class="contenido-panel">

        <h1 class="titulo-seccion">Productos</h1>

        <% if (typeof errorCarga !== 'undefined') { %>
            <p class="error-msg"><%= errorCarga %></p>
        <% } %>

        <table class="tabla-admin">
            <thead>
                <tr>
                    <th>Imagen</th>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Precio</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof productos !== 'undefined' && productos.length > 0) { %>
                    <% productos.forEach(function(producto) { %>
                        <tr>
                            <td>
                                <% if (producto.product_image) { %>
                                    <img src="<%= producto.product_image %>" alt="<%= producto.product_name %>" class="thumb-producto">
                                <% } else { %>
                                    <span class="sin-imagen">Sin imagen</span>
                                <% } %>
                            </td>
                            <td><%= producto.product_name %></td>
                            <td><%= producto.product_category %></td>
                            <td>$<%= producto.product_price %></td>
                            <td>
                                <span class="badge <%= producto.product_active ? 'badge-activo' : 'badge-inactivo' %>">
                                    <%= producto.product_active ? 'Activo' : 'Inactivo' %>
                                </span>
                            </td>
                            <td class="acciones-tabla">
                                <a href="/admin/productos/<%= producto.product_id %>/editar" class="btn-accion btn-editar">Editar</a>
                                <form action="/admin/productos/<%= producto.product_id %>/baja" method="POST" class="form-inline form-toggle-estado"
                                      data-nombre="<%= producto.product_name %>"
                                      data-accion="<%= producto.product_active ? 'desactivar' : 'activar' %>">
                                    <button type="button" class="btn-accion btn-baja">
                                        <%= producto.product_active ? 'Desactivar' : 'Activar' %>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6" class="celda-vacia">No hay productos cargados todavía.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

        <h1 class="titulo-seccion">Últimas ventas</h1>

        <table class="tabla-admin">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Fecha</th>
                    <th>Total</th>
                    <th>Productos</th>
                </tr>
            </thead>
            <tbody>
                <% if (typeof ventas !== 'undefined' && ventas.length > 0) { %>
                    <% ventas.forEach(function(venta) { %>
                        <tr>
                            <td><%= venta.sale_customer_name %></td>
                            <td><%= new Date(venta.sale_date).toLocaleDateString('es-AR') %></td>
                            <td>$<%= venta.sale_total %></td>
                            <td>
                                <% if (venta.Products && venta.Products.length > 0) { %>
                                    <%= venta.Products.map(function(p) { return p.product_name; }).join(', ') %>
                                <% } else { %>
                                    -
                                <% } %>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="4" class="celda-vacia">No hay ventas registradas todavía.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>

    </div>

    <!-- Modal de confirmación reutilizable para desactivar / activar productos -->
    <div id="modalConfirmacion" class="modal-overlay oculto">
        <div class="modal-caja">
            <h3 id="modalTitulo">Confirmar acción</h3>
            <p id="modalMensaje">¿Estás seguro?</p>
            <div class="modal-acciones">
                <button type="button" class="btn-secondary" id="modalCancelar">Cancelar</button>
                <button type="button" class="btn-primary" id="modalConfirmar">Confirmar</button>
            </div>
        </div>
    </div>

    <script>
        // Modal de confirmación para baja/activación de productos.
        // En vez de enviar el form directo, el botón abre el modal y
        // recién al confirmar se hace el submit real del form correspondiente.
        (function () {
            const modal = document.getElementById('modalConfirmacion');
            const modalTitulo = document.getElementById('modalTitulo');
            const modalMensaje = document.getElementById('modalMensaje');
            const btnCancelar = document.getElementById('modalCancelar');
            const btnConfirmar = document.getElementById('modalConfirmar');
            let formPendiente = null;

            function abrirModal(form) {
                formPendiente = form;
                const nombre = form.dataset.nombre;
                const accion = form.dataset.accion; // 'activar' o 'desactivar'

                modalTitulo.textContent = accion === 'activar' ? 'Activar producto' : 'Desactivar producto';
                modalMensaje.textContent = `¿Seguro que querés ${accion} "${nombre}"?`;

                modal.classList.remove('oculto');
                btnConfirmar.focus();
            }

            function cerrarModal() {
                modal.classList.add('oculto');
                formPendiente = null;
            }

            document.querySelectorAll('.form-toggle-estado').forEach(function (form) {
                form.querySelector('button').addEventListener('click', function () {
                    abrirModal(form);
                });
            });

            btnCancelar.addEventListener('click', cerrarModal);

            btnConfirmar.addEventListener('click', function () {
                if (formPendiente) {
                    formPendiente.submit();
                }
            });

            // Cerrar haciendo click fuera de la caja o con la tecla Escape
            modal.addEventListener('click', function (e) {
                if (e.target === modal) cerrarModal();
            });
            document.addEventListener('keydown', function (e) {
                if (e.key === 'Escape' && !modal.classList.contains('oculto')) cerrarModal();
            });
        })();
    </script>
</body>
</html>