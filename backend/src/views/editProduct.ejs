<!DOCTYPE html>
<html lang="es">
<head>
    <%- include('header', { tituloPagina: 'Editar producto' }) %>
</head>
<body class="panel-admin">
    <%- include('navbar', { activo: '' }) %>

    <div class="contenido-panel">

        <h1 class="titulo-seccion">Editar producto</h1>

        <% if (typeof error !== 'undefined') { %>
            <p class="error-msg"><%= error %></p>
        <% } %>
        <% if (typeof errores !== 'undefined' && errores.length > 0) { %>
            <ul class="error-msg lista-errores">
                <% errores.forEach(function(e) { %>
                    <li><%= e %></li>
                <% }); %>
            </ul>
        <% } %>

        <form action="/admin/productos/<%= producto.product_id %>/editar" method="POST" enctype="multipart/form-data" class="form-producto">

            <% if (producto.product_image) { %>
                <label>Imagen actual</label>
                <img src="<%= producto.product_image %>" alt="<%= producto.product_name %>" class="preview-imagen-actual">
            <% } %>

            <label for="product_name">Nombre</label>
            <input type="text" id="product_name" name="product_name" value="<%= producto.product_name %>" required>

            <label for="product_price">Precio</label>
            <input type="number" id="product_price" name="product_price" step="0.01" min="0" value="<%= producto.product_price %>" required>

            <label for="product_category">Categoría</label>
            <input type="text" id="product_category" name="product_category" value="<%= producto.product_category %>" required>

            <label for="product_description">Descripción</label>
            <textarea id="product_description" name="product_description" rows="4" required><%= producto.product_description %></textarea>

            <label for="product_image">Reemplazar imagen (opcional)</label>
            <input type="file" id="product_image" name="product_image" accept="image/png, image/jpeg, image/webp">

            <label for="product_active" class="check-label">
                <input type="checkbox" id="product_active" name="product_active" value="true" <%= producto.product_active ? 'checked' : '' %>>
                Producto activo
            </label>

            <div class="acciones-form">
                <a href="/admin/dashboard" class="btn-secondary">Cancelar</a>
                <button type="submit" class="btn-primary">Guardar cambios</button>
            </div>
        </form>

    </div>
</body>
</html>